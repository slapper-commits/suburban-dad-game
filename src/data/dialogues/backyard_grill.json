{
  "id": "backyard_grill",
  "startNode": "router",
  "nodes": {
    "router": {
      "id": "router",
      "text": "",
      "routes": [
        { "conditions": [{ "field": "flags.grillStatus", "op": "==", "value": "done" }], "nextNode": "done" },
        { "conditions": [{ "field": "flags.grillStatus", "op": "==", "value": "burnt" }], "nextNode": "burnt" },
        { "conditions": [{ "field": "flags.grillStatus", "op": "==", "value": "cooking" }], "nextNode": "cooking" },
        { "conditions": [{ "field": "flags.grillStatus", "op": "==", "value": "prepped" }], "nextNode": "prepped" },
        { "conditions": [{ "field": "flags.boughtCharcoal", "op": "==", "value": true }], "nextNode": "supplies" },
        { "conditions": [{ "field": "flags.grillStatus", "op": "==", "value": "supplies_bought" }], "nextNode": "supplies" }
      ],
      "next": "no_charcoal"
    },

    "no_charcoal": {
      "id": "no_charcoal",
      "text": "",
      "beats": [
        { "text": "Cold grates. You need charcoal first. Kingsford. Karen was very specific.", "mouth": "frown" },
        { "speaker": "Dad", "text": "\"To the QuikStop. Or the gas station. Someone sells charcoal.\"", "mouth": "neutral", "eyebrows": "raised" }
      ]
    },

    "supplies": {
      "id": "supplies",
      "text": "",
      "beats": [
        { "text": "Bag of Kingsford on the patio. Lighter fluid. Everything a man needs to fail quietly in his own backyard.", "mouth": "neutral" },
        { "speaker": "Dad", "text": "\"OK. Build the pyramid. Like Dad used to.\"", "mouth": "neutral", "eyebrows": "raised" }
      ],
      "choices": [
        {
          "text": "Build the fire (prep grill — 20 min)",
          "nextNode": "fire_built",
          "timeCost": 20,
          "effects": [
            { "type": "flag", "field": "grillStatus", "value": "prepped" }
          ]
        },
        {
          "text": "Light 'em fast and cook NOW — FLIP MINIGAME",
          "nextNode": "grill_launch",
          "timeCost": 5,
          "effects": [
            { "type": "flag", "field": "grillStatus", "value": "prepped" }
          ]
        },
        { "text": "Leave it for later", "nextNode": "leave" }
      ]
    },

    "fire_built": {
      "id": "fire_built",
      "text": "Coals are glowing. The fire accepts you as its caretaker. When the coals go ash-gray, come back to start cooking."
    },

    "prepped": {
      "id": "prepped",
      "text": "",
      "beats": [
        { "text": "Coals are glowing ash-gray. The grill is ready. The burgers are staring you down from the cooler.", "mouth": "grin" },
        { "speaker": "Dad", "text": "\"Showtime.\"", "mouth": "smirk", "eyebrows": "raised" }
      ],
      "choices": [
        {
          "text": "Start grilling — FLIP MINIGAME",
          "nextNode": "grill_launch",
          "timeCost": 5
        },
        { "text": "Wait a bit longer", "nextNode": "leave" }
      ]
    },

    "grill_launch": {
      "id": "grill_launch",
      "text": "",
      "exitScene": "MINIGAME:grill"
    },

    "cooking": {
      "id": "cooking",
      "text": "",
      "beats": [
        { "text": "Burgers are on. Grease pops. You smell it before you see it — smoke curling over the neighborhood.", "mouth": "grin" }
      ],
      "choices": [
        {
          "text": "Flip attentively — FLIP MINIGAME",
          "nextNode": "grill_launch",
          "timeCost": 5
        },
        {
          "text": "Leave them. They'll be fine.",
          "nextNode": "leave_cooking",
          "timeCost": 15,
          "effects": [
            { "type": "flag", "field": "grillStatus", "value": "burnt" },
            { "type": "flag", "field": "burnedBurgers", "value": true },
            { "type": "add", "field": "reputation", "value": -10 }
          ]
        }
      ]
    },

    "leave_cooking": {
      "id": "leave_cooking",
      "text": "You walk away. Fifteen minutes later you smell the mistake. By then it's black."
    },

    "done": {
      "id": "done",
      "text": "Platter of golden-brown burgers. You did a thing. The first thing you've done today, probably."
    },

    "burnt": {
      "id": "burnt",
      "text": "Charred discs. You know what they are because you made them. A stranger would need context."
    },

    "leave": {
      "id": "leave",
      "text": "The grill waits."
    }
  }
}
