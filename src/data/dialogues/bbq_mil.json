      "text": "",
      "beats": [
        { "speaker": "Mother-in-Law", "text": "She gestures at the lawn with one manicured nail. The nail is a verdict.", "mouth": "neutral", "eyes": "angry", "eyebrows": "raised" },
        { "speaker": "Dad", "text": "\"It's a — a design choice, Barb. Very modern. Very... Scandinavian.\"", "mouth": "smile", "eyes": "wide", "eyebrows": "worried" },
        { "speaker": "Mother-in-Law", "text": "\"Mm. It's certainly... interesting.\"", "mouth": "smile", "eyes": "angry", "eyebrows": "raised" },
        { "text": "When Barb says 'interesting,' small mammals go quiet. Lawyers get involved.", "mouth": "sleepy" }
      ],
      "choices": [
        {
          "text": "\"It's a European style, Barb.\"",
          "nextNode": "barb_skeptical"
        },
        {
          "text": "\"The mower pulls to the left\"",
          "nextNode": "barb_reply"
        }
