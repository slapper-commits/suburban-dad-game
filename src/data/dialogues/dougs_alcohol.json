        {
          "text": "Fold and walk",
          "nextNode": "poker_lose",
          "timeCost": 30,
          "effects": [
            { "type": "add", "field": "flags.cash", "value": -200 }
          ]
        }
      ]
    },
    "poker_win": {
      "id": "poker_win",
      "text": "Six hundred dollars in a suburban dad's cargo shorts. This is not who you were this morning.",
      "next": "exit_home"
    },
    "poker_lose": {
      "id": "poker_lose",
      "text": "Two hundred gone. The stranger doesn't say goodbye. You don't either.",
      "next": "exit_home"
    },
    "poker_exit": {
      "id": "poker_exit",
      "text": "You push back from the table. Smart money knows when to walk."
    },
    "decline": {
      "id": "decline",
      "speaker": "Doug",
      "text": "Doug shrugs. 'Your loss, brother. I'll be here.' He will definitely be here."
    },
    "exit_home": {
      "id": "exit_home",
      "text": "You head back toward your place.",
      "exitScene": "frontyard"
    },
    "exit_home_drunk": {
