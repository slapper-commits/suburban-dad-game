      "id": "intro",
      "text": "",
      "beats": [
        { "text": "She's mid-routine. The pole knows her better than anyone in her life, probably.", "mouth": "neutral" },
        { "speaker": "Amber", "text": "Hey, suit.", "mouth": "pouty", "eyes": "sultry" },
        { "speaker": "Dad", "text": "It's a polo, actually. From... the outlet store.", "mouth": "frown", "eyebrows": "worried" },
        { "speaker": "Amber", "text": "Cute.", "mouth": "smirk" }
      ],
      "choices": [
        {
          "text": "Tip her $20",
          "nextNode": "warmed_up",
          "effects": [
            { "type": "add", "field": "flags.cash", "value": -20 },
            { "type": "set", "field": "flags.lipstick", "value": true }
