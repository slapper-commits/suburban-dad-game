        { "speaker": "Tony", "text": "Yeah you. You look like a man with a mortgage.", "mouth": "smirk" },
        { "speaker": "Tony", "text": "You ever play three-card monte? Easy money. I need a fourth for a private game.", "mouth": "grin", "eyes": "shades" },
        { "text": "He fans three cards on the bar. The queen is right there. She's RIGHT THERE.", "mouth": "sleepy" }
      ],
      "choices": [
        {
          "text": "\"Fine. $50 to play.\"",
          "nextNode": "bet_50",
          "conditions": [{ "field": "flags.cash", "op": ">=", "value": 50 }],
          "timeCost": 10,
          "effects": [
            { "type": "add", "field": "flags.cash", "value": -50 },
            { "type": "add", "field": "vices.gambling", "value": 1 },
            { "type": "set", "field": "flags.tony_met", "value": true }
          ]
        },
        {
          "text": "\"$200. I'm all in.\"",
          "nextNode": "bet_200",
          "conditions": [{ "field": "flags.cash", "op": ">=", "value": 200 }],
          "timeCost": 15,
          "effects": [
            { "type": "add", "field": "flags.cash", "value": -200 },
            { "type": "add", "field": "vices.gambling", "value": 1 },
            { "type": "set", "field": "flags.tony_met", "value": true }
          ]
        },
        {
          "text": "\"What if I don't have cash?\"",
          "nextNode": "no_cash",
          "conditions": [{ "field": "flags.cash", "op": "<", "value": 50 }]
        },
        { "text": "\"Hard pass, Tony.\"", "nextNode": "pass" }
      ]
    },

