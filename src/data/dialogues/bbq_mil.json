    "normal_convo": {
      "id": "normal_convo",
      "speaker": "Mother-in-Law",
      "text": "\"David. The lawn looks... adequate. Have you put on weight?\" Her perfume predates the Cold War.",
      "choices": [
        {
          "text": "\"Great to see you too, Barb.\"",
          "nextNode": "barb_reply",
