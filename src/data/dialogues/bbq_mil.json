          "timeCost": 5,
          "effects": [
            { "type": "add", "field": "suspicion", "value": 8 }
          ]
        }
      ]
    },
    "drunk_convo": {
      "id": "drunk_convo",
      "speaker": "Mother-in-Law",
      "text": "",
      "beats": [
        { "speaker": "Mother-in-Law", "text": "She leans in. Sniffs. Twice. Recoils a millimeter.", "mouth": "frown", "eyes": "angry", "eyebrows": "raised" },
        { "speaker": "Mother-in-Law", "text": "\"David. Are you... feeling quite yourself today?\"", "mouth": "neutral", "eyebrows": "raised" },
        { "speaker": "Dad", "text": "\"Barb! Never better. Totally fine. 100%. Fine.\"", "mouth": "smile", "eyes": "drunk", "eyebrows": "raised" },
        { "speaker": "Mother-in-Law", "text": "\"Karen deserves a partner who shows up. Pass the potato salad, dear.\"", "mouth": "smile", "eyes": "angry", "eyebrows": "neutral" }
      ],
      "choices": [
        {
          "text": "\"It's a BBQ, Barb. People drink at BBQs.\"",
          "nextNode": "barb_furious",
          "timeCost": 10,
          "effects": [
            { "type": "add", "field": "suspicion", "value": 10 }
          ]
        },
        {
          "text": "\"Sunstroke. I was mowing all day.\"",
          "nextNode": "barb_skeptical",
          "timeCost": 10,
          "effects": [
            { "type": "add", "field": "suspicion", "value": 3 }
          ]
        }
      ]
