    },

    "warmed_up": {
      "id": "warmed_up",
      "text": "",
      "beats": [
        { "speaker": "Amber", "text": "Mmm. Look at you.", "mouth": "pouty", "eyes": "sultry" },
        { "text": "She leans down. The lipstick on your collar is going to be a whole forensic situation later.", "mouth": "neutral" },
        { "speaker": "Dad", "text": "I have a wife.", "mouth": "frown", "eyes": "wide" },
        { "speaker": "Amber", "text": "I know, baby. We all do.", "mouth": "smirk" }
      ]
    },

    "she_opens_up": {
      "id": "she_opens_up",
      "text": "",
      "beats": [
        { "speaker": "Amber", "text": "Slow night. Tuesdays, you know.", "mouth": "neutral", "eyes": "lidded" },
        { "speaker": "Dad", "text": "It's, uh — it's Saturday.", "mouth": "neutral", "eyebrows": "raised" },
        { "speaker": "Amber", "text": "Is it. Huh.", "mouth": "smirk" },
        { "text": "She sits at the edge of the stage. The music keeps going without her.", "mouth": "neutral" },
        { "speaker": "Amber", "text": "Got a kid. Three. Want to be a vet someday. Animals don't ask questions.", "mouth": "neutral", "eyes": "lidded" },
        { "speaker": "Dad", "text": "...that's a good dream.", "mouth": "smile", "eyebrows": "worried" }
      ]
    },

    "to_vip": {
      "id": "to_vip",
      "text": "",
      "beats": [
        { "speaker": "Amber", "text": "The back. Sure.", "mouth": "smirk", "eyes": "sultry" },
        { "text": "She slides off the stage and tilts her head toward a curtain in the corner.", "mouth": "neutral" },
        { "speaker": "Amber", "text": "Come on, polo.", "mouth": "pouty" }
