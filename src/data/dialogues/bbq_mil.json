    "suspicious_convo": {
      "id": "suspicious_convo",
      "speaker": "Mother-in-Law",
      "text": "\"You look... disheveled. Karen called me earlier. She sounded upset.\" The stare could peel paint.",
      "choices": [
        {
          "text": "\"Just been busy with the grill, Barb.\"",
          "nextNode": "barb_skeptical",
          "timeCost": 10,
